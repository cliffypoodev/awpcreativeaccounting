# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── Database (Postgres 16 + pgvector) ──────────────────
DATABASE_URL=postgresql://invoiceforge:invoiceforge@localhost:5432/invoiceforge

# ─── Redis (cache + BullMQ queue) ───────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Better Auth) ─────────────────────────────────
BETTER_AUTH_SECRET=replace-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Email (Resend) ─────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM="InvoiceForge <invoices@yourdomain.com>"

# ─── Storage (Cloudflare R2) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=invoiceforge
R2_PUBLIC_URL=

# ─── PDF (Gotenberg) ────────────────────────────────────
GOTENBERG_URL=http://localhost:3001

# ─── AI Service (FastAPI) ───────────────────────────────
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OCR provider: google_document_ai | aws_textract | none
OCR_PROVIDER=none
